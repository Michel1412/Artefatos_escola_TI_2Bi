<mxfile host="app.diagrams.net">
  <diagram name="Página-1" id="G2TZfRd0bZyd73M-wK2c">
    <mxGraphModel dx="1089" dy="1587" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml LogViewer_DiagramaClasses_Unificado\n\nskinparam backgroundColor #FFFFFF\nskinparam classBackgroundColor #EBF8FF\nskinparam classBorderColor #005A9C\nskinparam classAttributeFontColor #333333\nskinparam classFontColor #1A1A1A\nskinparam classFontSize 10\nskinparam classAttributeFontSize 10\nskinparam arrowColor #005A9C\nskinparam arrowThickness 1.5\nskinparam linetype ortho\nskinparam padding 6\nskinparam roundcorner 8\nskinparam classAttributeIconSize 0\nskinparam shadowing false\n\ntitle LogViewer - Diagrama de Classes Unificado\n\n&#39; ===========================================================\n&#39;  PACOTE: AUTENTICACAO E IDENTIDADE\n&#39; ===========================================================\npackage \&quot;Autenticação e Identidade\&quot; #DDEEFF {\n\n  class ClerkIdentity {\n    - clerkUserId : String\n    - sessionId : String\n    - accessToken : String\n    - backendToken : String\n    - refreshToken : String\n    - role : String\n    - plano : String\n    - tenantId : String\n    - metadata : Map&lt;String, Object&gt;\n    - claims : Map&lt;String, Object&gt;\n    - permissoes : List&lt;String&gt;\n    - issuedAt : DateTime\n    - expiresAt : DateTime\n    - autenticado : Boolean\n    --\n    + carregarClaims(jwt : String) : void\n    + obterRole() : String\n    + obterPlano() : String\n    + obterTenantId() : String\n    + obterMetadata(chave : String) : Object\n    + atualizarMetadata(chave : String, valor : Object) : void\n    + validarExpiracao() : Boolean\n    + possuiPermissao(permissao : String) : Boolean\n    + renovarSessao() : void\n    + invalidarSessao() : void\n    + obterClaims() : Map&lt;String, Object&gt;\n    + estaAutenticado() : Boolean\n  }\n\n  class AuthenticationManager {\n    - sessionId : String\n    - accessToken : String\n    - backendToken : String\n    - refreshToken : String\n    - claims : Map&lt;String, Object&gt;\n    - metadata : Map&lt;String, Object&gt;\n    - role : String\n    - permissoes : List&lt;String&gt;\n    - tenantId : String\n    - planoAssinatura : String\n    - issuedAt : DateTime\n    - expiresAt : DateTime\n    - autenticado : Boolean\n    - ultimoRefresh : DateTime\n    --\n    + carregarToken(jwt : String) : void\n    + extrairClaims() : Map&lt;String, Object&gt;\n    + obterRole() : String\n    + obterPermissoes() : List&lt;String&gt;\n    + obterTenantId() : String\n    + obterPlanoAssinatura() : String\n    + validarToken() : Boolean\n    + validarPermissao(permissao : String) : Boolean\n    + renovarToken() : void\n    + invalidarSessao() : void\n    + compartilharContexto() : ContextoAutenticacao\n    + atualizarMetadata(metadata : Map&lt;String, Object&gt;) : void\n    + obterClaimsCustomizadas() : Map&lt;String, Object&gt;\n    + estaAutenticado() : Boolean\n  }\n\n  class NotifyAuth2Factor {\n    - solicitacaoId : String (UUID)\n    - usuarioId : String\n    - tokenTemporario : String\n    - dispositivoMobileId : String\n    - status : Status2FA\n    - dataCriacao : DateTime\n    - dataExpiracao : DateTime\n    - dataResposta : DateTime\n    - tentativas : Integer\n    - tempoLimiteSegundos : Integer\n    - biometriaObrigatoria : Boolean\n    - ipOrigem : String\n    - dispositivoOrigem : String\n    - ativo : Boolean\n    --\n    + gerarSolicitacao(usuarioId : String) : String\n    + gerarTokenTemporario() : String\n    + enviarNotificacaoPush() : void\n    + validarBiometria() : Boolean\n    + aprovarSolicitacao() : void\n    + rejeitarSolicitacao() : void\n    + expirarSolicitacao() : void\n    + validarToken(token : String) : Boolean\n    + verificarExpiracao() : Boolean\n    + obterStatus() : Status2FA\n    + registrarTentativa() : void\n    + registrarEventoSeguranca(evento : String) : void\n    + cancelarSolicitacao() : void\n    + estaAprovada() : Boolean\n  }\n\n  enum Status2FA {\n    PENDENTE\n    AGUARDANDO_BIOMETRIA\n    APROVADO\n    REJEITADO\n    EXPIRADO\n    CANCELADO\n  }\n\n}\n\n&#39; ===========================================================\n&#39;  PACOTE: DOMÍNIO PRINCIPAL - USUÁRIO E SISTEMA\n&#39; ===========================================================\npackage \&quot;Domínio: Usuário e Sistema\&quot; #DFFDE8 {\n\n  class Usuario {\n    - id : String (UUID)\n    - cnpj : String\n    - sistemasCadastrados : List&lt;String&gt;\n    - _2faAtivado : Boolean\n    - contextoEmpresa : ContextoEmpresa\n    --\n    + ativar2FA() : void\n    + atualizarContexto() : void\n    + registrarErroInterface() : void\n    + acessarRelatorios() : void\n    + solicitarExportacao() : void\n  }\n\n  class Sistema {\n    - id : String (UUID)\n    - nome : String\n    - tenantId : String\n    - tokenSDK : String\n    --\n    + validarSistema() : Boolean\n  }\n\n  class ContextoEmpresa {\n    - ramoAtuacao : String\n    - stack : String\n    - criticidade : String\n  }\n\n}\n\n&#39; ===========================================================\n&#39;  PACOTE: CAPTURA E INGESTÃO DE LOGS\n&#39; ===========================================================\npackage \&quot;Captura e Ingestão\&quot; #FFF9DB {\n\n  class CapturadorDeErroSDK &lt;&lt;Secondary Adapter&gt;&gt; {\n    - apiEndpoint : String\n    - apiToken : String\n    - nomeSistema : String\n    --\n    + configurar(endpoint : String, token : String) : void\n    + capturarErro(erro : Throwable) : Log\n    + enviarLog(log : Log) : RespostaIngestao\n  }\n\n  class CapturadorErroInterface {\n    - id : String (UUID)\n    - usuarioId : String\n    - sistemaId : String\n    - mensagemErro : String\n    - criticidade : Enum\n    --\n    + capturarErroManual() : Erro\n    + validarDadosErro() : Boolean\n    + enviarParaTratamento() : void\n  }\n\n  class LogController {\n    --\n    + receberLog(dto : LogDTO, token : String) : RespostaIngestao\n    + listarLogs(tenantId : String) : List&lt;Log&gt;\n    + obterLog(id : String) : Log\n    + confirmarLeitura(id : String) : RespostaHttp\n  }\n\n  interface ParserStrategy {\n    + suporta(extensao : String) : Boolean\n    + parse(conteudoBruto : String) : Log\n  }\n\n}\n\n&#39; ===========================================================\n&#39;  PACOTE: ENTIDADE DE DOMÍNIO - LOG\n&#39; ===========================================================\npackage \&quot;Entidade de Domínio: Log\&quot; #FDE8FF {\n\n  class Log {\n    - id : String (UUID)\n    - tenantId : String\n    - sistemaOrigem : String\n    - mensagem : String\n    - stackTrace : String\n    - nivel : String\n    - origem : String\n    - status : Enum {NAO_SOLUCIONADO, SOLUCIONADO, ARQUIVADO, IGNORADO}\n    - formato : String\n    - timestamp : LocalDateTime\n    - isRead : Boolean\n    - dadosMascarados : Boolean\n    - hashIdentificacao : String\n    - contadorOcorrencias : Integer\n    - contextoAplicado : ContextoEmpresa\n    --\n    + marcarComoLido() : void\n    + estaLido() : Boolean\n    + definirNivel(nivel : String) : void\n    + marcarDadosMascarados() : void\n  }\n\n  class Erro {\n    - id : String (UUID)\n    - mensagem : String\n    - criticidade : Enum\n    - status : Enum {NAO_SOLUCIONADO, SOLUCIONADO, ARQUIVADO, IGNORADO}\n    --\n    + classificarErro() : void\n    + marcarComoResolvido() : void\n  }\n\n  class LogTratado {\n    - id : String (UUID)\n    - conteudo : String\n    - criticidade : Enum\n    --\n    + consultarDetalhes() : String\n  }\n\n}\n\n&#39; ===========================================================\n&#39;  PACOTE: PROCESSAMENTO E INTELIGÊNCIA\n&#39; ===========================================================\npackage \&quot;Processamento e Inteligência\&quot; #FFF0E8 {\n\n  class ProcessamentoDeLogs {\n    --\n    + enfileirar(log : Log) : void\n    + consumirDaFila() : void\n    + processarEValidar(log : Log) : Log\n    + ofuscarDadosSensiveis(log : Log) : Log\n    + classificarErro(log : Log) : String\n    + persistir(log : Log) : Boolean\n    + notificarTempoReal(log : Log) : void\n    + executarVarredura() : void\n    + selecionarEstrategia(extensao : String) : ParserStrategy\n  }\n\n  class ServicoTratamentoLog {\n    - logBruto : String\n    - logSanitizado : String\n    - contextoAplicado : ContextoEmpresa\n    - criticidade : Enum\n    --\n    + processarLog() : LogTratado\n    + sanitizarDadosSensiveis() : String\n    + aplicarContexto() : LogEnriquecido\n  }\n\n  interface LLMService {\n    - provider : String\n    - apiKey : String\n    - endpoint : String\n    - timeout : Integer\n    - contextoEmpresa : ContextoEmpresa\n    - modeloAtivo : String\n    - temperatura : Float\n    - maxTokens : Integer\n    - ativo : Boolean\n    --\n    + analisarLog(log : Log) : String\n    + montarContexto(usuario : Usuario) : String\n    + validarDisponibilidade() : Boolean\n    + configurarModelo(modelo : String) : void\n    + definirTemperatura(valor : Float) : void\n    + gerarPrompt(log : Log) : String\n    + registrarFalha(mensagem : String) : void\n    + obterStatusServico() : String\n  }\n\n  class SugestaoDeLogs {\n    - provedorIA : String\n    --\n    + solicitarSugestao(log : Log) : SugestaoIA\n    + gerarSolucao(log : Log) : String\n  }\n\n  class ServicoSugestao {\n    - erroId : String (UUID)\n    - statusConsentimento : Enum\n    - statusSolucao : Enum\n    - linkAgente : String\n    --\n    + solicitarConsentimento() : void\n    + gerarSugestao() : Sugestao\n    + aceitarSugestao() : void\n  }\n\n}\n\n&#39; ===========================================================\n&#39;  PACOTE: NOTIFICAÇÕES E ALERTAS\n&#39; ===========================================================\npackage \&quot;Notificações e Alertas\&quot; #E8F4FD {\n\n  class ServicoNotificacao {\n    - usuarioId : String (UUID)\n    - tipoCanal : Enum {EMAIL, PUSH, WEBSOCKET}\n    - statusEnvio : Enum\n    - contadorAgrupamento : Integer\n    --\n    + notificarErro() : void\n    + enviarEmail() : void\n    + enviarPushMobile() : void\n    + emitirWebSocket() : void\n  }\n\n}\n\n&#39; ===========================================================\n&#39;  PACOTE: PERSISTÊNCIA DE LOGS\n&#39; ===========================================================\npackage \&quot;Persistência\&quot; #E8FDF5 {\n\n  class ServicoPersistenciaLog {\n    - id : String (UUID)\n    - sistemaId : String\n    - hashIdentificacao : String\n    - statusPersistencia : Enum {SUCESSO, FALHA, AGRUPADO}\n    --\n    + persistir(log : LogTratado, sistemaId : String) : DocumentoLog\n    - gerarHashIdentificacao(log : LogTratado) : String\n    - buscarOcorrenciaRecente(hash : String) : DocumentoLog\n  }\n\n  class ServicoFiltragemLog {\n    - usuarioId : String (UUID)\n    - filtrosSelecionados : FiltroLog\n    - totalResultados : Long\n    --\n    + filtrarLogs() : Page&lt;LogTratado&gt;\n    + buscarPorTexto() : List&lt;LogTratado&gt;\n    + filtrarPorCriticidade() : List&lt;LogTratado&gt;\n  }\n\n}\n\n&#39; ===========================================================\n&#39;  PACOTE: RELATÓRIOS E EXPORTAÇÃO\n&#39; ===========================================================\npackage \&quot;Relatórios e Exportação\&quot; #FDF5E8 {\n\n  class FiltroRelatorio {\n    - id : String (UUID)\n    - dataInicial : DateTime\n    - dataFinal : DateTime\n    - criticidade : Enum\n    --\n    + aplicarFiltro() : List&lt;Erro&gt;\n    + validarPeriodo() : Boolean\n  }\n\n  class GerarRelatorio {\n    - usuarioId : String (UUID)\n    - statusGeracao : Enum\n    --\n    + gerarRelatorio() : Relatorio\n    + buscarDadosFiltrados() : List&lt;LogTratado&gt;\n    + salvarRelatorio() : void\n  }\n\n  class Relatorio {\n    - id : String (UUID)\n    - titulo : String\n    - totalLogs : Long\n    - totalErros : Long\n    - statusRelatorio : Enum\n    --\n    + calcularTotais() : void\n    + gerarResumo() : String\n  }\n\n  class ExportarRelatorio {\n    - relatorioId : String (UUID)\n    - formatoExportacao : Enum {PDF, EXCEL}\n    - urlDownload : String\n    --\n    + validarFormato() : Boolean\n    + gerarLinkDownload() : String\n  }\n\n  class DocumentoRelatorio {\n    - id : String (UUID)\n    - nomeArquivo : String\n    - formato : Enum {PDF, EXCEL}\n    - urlDownload : String\n    --\n    + gerarArquivo() : void\n    + disponibilizarDownload() : String\n  }\n\n}\n\n&#39; ===========================================================\n&#39;  PACOTE: ASSINATURA E PAGAMENTO\n&#39; ===========================================================\npackage \&quot;Assinatura e Pagamento\&quot; #F5E8FD {\n\n  class GerenciadorAssinatura {\n    - id : String (UUID)\n    - tenantId : String\n    - valorAtualCalculado : Decimal\n    - statusAssinatura : Enum {ATIVA, PENDENTE, INADIMPLENTE, CANCELADA}\n    - totalSistemasContratados : Integer\n    --\n    + calcularValorProporcional(tenantId : String) : Decimal\n    + contratarPlano(tenantId : String, plano : PlanoBase) : Assinatura\n    + verificarInadimplencia(tenantId : String) : Boolean\n    - validarPermissaoAdmin(adminId : String) : Boolean\n  }\n\n  class ServicoProcessamentoPagamento {\n    - id : String (UUID)\n    - assinaturaId : String\n    - transacaoGatewayId : String\n    - statusPagamento : Enum {PENDENTE, PAGO, RECUSADO, ESTORNADO}\n    --\n    + processarPagamento(assinaturaId : String, valor : Decimal) : TransacaoGateway\n    + processarNotificacaoWebhook(payload : Object) : void\n    - validarAutenticidadeWebhook(payload : Object, sig : String) : Boolean\n  }\n\n  class ApiDePagamento &lt;&lt;Secondary Adapter&gt;&gt; {\n    - baseUrl : String\n    - apiKey : String\n    - webhookSecret : String\n    --\n    + criarCobranca(dados : DadosCobranca) : TransacaoExterna\n    + consultarTransacao(gatewayId : String) : DetalhesTransacao\n    + validarAssinaturaWebhook(payload : String, sig : String) : Boolean\n  }\n\n}\n\n&#39; ===========================================================\n&#39;  RELACIONAMENTOS - AUTENTICAÇÃO\n&#39; ===========================================================\nClerkIdentity \&quot;1\&quot; --&gt; \&quot;1\&quot; AuthenticationManager : fornece identidade\\nautenticada ao manager\nAuthenticationManager \&quot;1\&quot; --&gt; \&quot;1\&quot; NotifyAuth2Factor : orquestra fluxo\\nde 2FA quando ativado\nNotifyAuth2Factor --&gt; Status2FA : possui status\nAuthenticationManager \&quot;1\&quot; --&gt; \&quot;1\&quot; Usuario : resolve identidade\\npara o domínio\n\n&#39; ===========================================================\n&#39;  RELACIONAMENTOS - USUÁRIO E SISTEMA\n&#39; ===========================================================\nUsuario \&quot;1\&quot; --&gt; \&quot;N\&quot; Sistema : cadastra e gerencia\nUsuario \&quot;1\&quot; --&gt; \&quot;1\&quot; ContextoEmpresa : configura contexto\nSistema \&quot;1\&quot; --&gt; \&quot;1\&quot; ContextoEmpresa : aplica contexto\\nno processamento\n\n&#39; ===========================================================\n&#39;  RELACIONAMENTOS - CAPTURA E INGESTÃO\n&#39; ===========================================================\nCapturadorDeErroSDK ..&gt; LogController : envia log via HTTP\nCapturadorDeErroSDK ..&gt; Log : cria instância\nCapturadorErroInterface \&quot;1\&quot; --&gt; \&quot;1\&quot; Sistema : vincula ao sistema\nCapturadorErroInterface \&quot;1\&quot; --&gt; \&quot;1\&quot; Erro : cria erro\nCapturadorErroInterface ..&gt; LogController : encaminha para ingestão\nLogController ..&gt; ProcessamentoDeLogs : delega processamento\nLogController ..&gt; Log : gerencia ciclo de vida\nLogController ..&gt; ServicoSugestao : solicita sugestão ao aceitar\n\n&#39; ===========================================================\n&#39;  RELACIONAMENTOS - PROCESSAMENTO E INTELIGÊNCIA\n&#39; ===========================================================\nProcessamentoDeLogs ..&gt; Log : processa e enriquece\nProcessamentoDeLogs ..&gt; ParserStrategy : usa estratégia de parse\nProcessamentoDeLogs ..&gt; ServicoNotificacao : dispara notificação\\napós processar\nProcessamentoDeLogs \&quot;1\&quot; --&gt; \&quot;1\&quot; ServicoPersistenciaLog : persiste log\\ntratado\nServicoTratamentoLog \&quot;1\&quot; --&gt; \&quot;1\&quot; ContextoEmpresa : aplica contexto\nServicoTratamentoLog ..&gt; LogTratado : produz log tratado\nServicoTratamentoLog \&quot;1\&quot; --&gt; \&quot;1\&quot; ServicoNotificacao : dispara alerta\\napós processar erro\nSugestaoDeLogs ..&gt; LLMService : delega análise ao LLM\nSugestaoDeLogs ..&gt; Log : analisa log para sugestão\nServicoSugestao \&quot;1\&quot; --&gt; \&quot;1\&quot; ServicoNotificacao : notifica ao gerar\\nsugestão\nServicoSugestao ..&gt; SugestaoDeLogs : usa para gerar solução\n\n&#39; ===========================================================\n&#39;  RELACIONAMENTOS - USUÁRIO → SERVIÇOS CORE\n&#39; ===========================================================\nUsuario \&quot;1\&quot; --&gt; \&quot;N\&quot; ServicoTratamentoLog : aciona processamento\\npelo contexto configurado\nServicoFiltragemLog \&quot;N\&quot; --&gt; \&quot;1\&quot; Usuario : filtra logs por usuário\nServicoSugestao \&quot;N\&quot; --&gt; \&quot;1\&quot; Usuario : apresenta sugestão\\npara consentimento\nUsuario \&quot;1\&quot; --&gt; \&quot;N\&quot; CapturadorErroInterface : registra erro\nUsuario \&quot;1\&quot; --&gt; \&quot;N\&quot; Relatorio : visualiza relatórios\nSistema \&quot;1\&quot; --&gt; \&quot;N\&quot; Relatorio : possui relatórios associados\n\n&#39; ===========================================================\n&#39;  RELACIONAMENTOS - FILTRAGEM E PERSISTÊNCIA\n&#39; ===========================================================\nServicoTratamentoLog \&quot;1\&quot; --&gt; \&quot;N\&quot; ServicoFiltragemLog : fornece logs\\ntratados para consulta\nServicoPersistenciaLog ..&gt; LogTratado : recebe e persiste\nServicoFiltragemLog ..&gt; LogTratado : consulta logs tratados\n\n&#39; ===========================================================\n&#39;  RELACIONAMENTOS - RELATÓRIOS E EXPORTAÇÃO\n&#39; ===========================================================\nGerarRelatorio \&quot;1\&quot; --&gt; \&quot;1\&quot; FiltroRelatorio : usa filtro\nGerarRelatorio \&quot;1\&quot; --&gt; \&quot;N\&quot; LogTratado : consulta logs\nGerarRelatorio \&quot;1\&quot; --&gt; \&quot;N\&quot; Erro : consulta erros\nGerarRelatorio \&quot;1\&quot; --&gt; \&quot;1\&quot; Relatorio : gera relatório\nRelatorio \&quot;1\&quot; --&gt; \&quot;1\&quot; FiltroRelatorio : mantém filtro aplicado\nRelatorio \&quot;1\&quot; --&gt; \&quot;N\&quot; Erro : consolida erros\nRelatorio \&quot;1\&quot; --&gt; \&quot;N\&quot; LogTratado : consolida logs\nUsuario \&quot;1\&quot; --&gt; \&quot;N\&quot; ExportarRelatorio : solicita exportação\nExportarRelatorio \&quot;1\&quot; --&gt; \&quot;1\&quot; Relatorio : exporta\nExportarRelatorio \&quot;1\&quot; --&gt; \&quot;1\&quot; DocumentoRelatorio : gera documento\nRelatorio \&quot;1\&quot; --&gt; \&quot;N\&quot; DocumentoRelatorio : possui documentos\n\n&#39; ===========================================================\n&#39;  RELACIONAMENTOS - ASSINATURA E PAGAMENTO\n&#39; ===========================================================\nGerenciadorAssinatura \&quot;1\&quot; --&gt; \&quot;1\&quot; ServicoProcessamentoPagamento : solicita geração\\nde cobrança e checkout\nServicoProcessamentoPagamento \&quot;1\&quot; --&gt; \&quot;1\&quot; GerenciadorAssinatura : atualiza status da\\nconta após aprovação\nServicoProcessamentoPagamento \&quot;1\&quot; --&gt; \&quot;1\&quot; ApiDePagamento : consome serviços REST\\ndo gateway externo\nApiDePagamento \&quot;1\&quot; --&gt; \&quot;1\&quot; ServicoProcessamentoPagamento : dispara eventos via\\nchamada de Webhook\nGerenciadorAssinatura \&quot;1\&quot; --&gt; \&quot;N\&quot; ServicoPersistenciaLog : dita regras de bloqueio\\npor inadimplência\nGerenciadorAssinatura \&quot;1\&quot; --&gt; \&quot;1\&quot; Usuario : gerencia assinatura\\ndo tenant (CNPJ)\nSistema \&quot;1\&quot; --&gt; \&quot;1\&quot; GerenciadorAssinatura : incrementa valor\\nao adicionar sistema\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="5UaN_wbpOJFoAGwqoRqa-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="3418" width="4478" x="1430" y="380" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
